    <table>
      <thead><tr><th>Name</th><th>City</th><th>State</th><th>Region</th></tr></thead>
      <tbody>
        <% venues.forEach(v => { %>
          <tr>
            <td><%= v.name %></td>
            <td><%= v.city %></td>
            <td><%= v.state %></td>
            <td><%= v.region %></td>
