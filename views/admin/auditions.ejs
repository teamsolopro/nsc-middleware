<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>NSC Admin — Auditions</title>
  <link rel="stylesheet" href="/public/admin.css">
</head>
<body>
  <%- include('_nav') %>
  <main>
    <h1>Auditions</h1>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <details class="form-panel">
      <summary>Add Audition</summary>
      <form method="POST" action="/admin/auditions">

        <h3 style="margin-top:0">Show Info</h3>
        <label>Title <input type="text" name="title" required></label>
        <label>Author <input type="text" name="author"></label>
        <label>Composer <input type="text" name="composer"></label>
        <label>Show Type
          <select name="showType">
            <option value="">—</option>
            <option value="musical">Musical</option>
            <option value="play">Play</option>
            <option value="improv">Improv</option>
            <option value="opera">Opera</option>
            <option value="dance">Dance</option>
            <option value="other">Other</option>
          </select>
        </label>
        <label>Description <textarea name="description" rows="2"></textarea></label>
        <label>Union Status
          <select name="unionType">
            <option value="">—</option>
            <option value="AEA">AEA</option>
            <option value="non-union">Non-Union</option>
            <option value="both">Both</option>
          </select>
        </label>

        <h3>Company, Venue &amp; Linked Production</h3>
        <label>Company
          <select name="linkedCompanyId">
            <option value="">— Not linked —</option>
            <% companies.forEach(c => { %>
              <option value="<%= c._id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </label>
        <label>Venue
          <select name="linkedVenueId">
            <option value="">— Not linked —</option>
            <% venues.forEach(v => { %>
              <option value="<%= v._id %>"><%= v.name %></option>
            <% }) %>
          </select>
        </label>
        <label>Linked Production (optional)
          <select name="linkedProductionId">
            <option value="">— None —</option>
            <% productions.forEach(p => { %>
              <option value="<%= p._id %>"><%= p.show && p.show.title %></option>
            <% }) %>
          </select>
        </label>

        <h3>Audition Dates</h3>
        <p style="font-size:13px;color:#666;margin:0 0 8px">Add up to three audition dates.</p>
        <% for (let i = 0; i < 3; i++) { %>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;margin-bottom:8px">
            <label>Date <input type="date" name="auditionDate"></label>
            <label>Start Time <input type="time" name="auditionStartTime"></label>
            <label>End Time <input type="time" name="auditionEndTime"></label>
            <label>Format
              <select name="auditionFormat">
                <option value="">—</option>
                <option value="open call">Open Call</option>
                <option value="by appointment">By Appointment</option>
                <option value="virtual">Virtual</option>
              </select>
            </label>
          </div>
        <% } %>

        <h3>Production Dates</h3>
        <label>Show Opens <input type="date" name="showOpens"></label>
        <label>Show Closes <input type="date" name="showCloses"></label>
        <label>Rehearsals Begin <input type="date" name="rehearsalStart"></label>

        <h3>Who They're Looking For</h3>
        <label>Age Ranges (select all that apply)
          <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:4px">
            <% ['children','teens','young_adults','adults','seniors','all'].forEach(a => { %>
              <label style="flex-direction:row;gap:4px;font-size:14px;text-transform:capitalize">
                <input type="checkbox" name="ageRanges" value="<%= a %>"> <%= a.replace('_',' ') %>
              </label>
            <% }) %>
          </div>
        </label>
        <label style="flex-direction:row;gap:8px;margin-top:8px">
          Gender Open &nbsp;
          <input type="checkbox" name="genderOpen">
          &nbsp;&nbsp; Male Roles &nbsp;
          <input type="checkbox" name="genderMale">
          &nbsp;&nbsp; Female Roles &nbsp;
          <input type="checkbox" name="genderFemale">
        </label>

        <h3>Requirements</h3>
        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:12px">
          <label style="flex-direction:row;gap:4px;font-size:14px"><input type="checkbox" name="preparedSong"> Prepared Song</label>
          <label style="flex-direction:row;gap:4px;font-size:14px"><input type="checkbox" name="coldReading"> Cold Reading</label>
          <label style="flex-direction:row;gap:4px;font-size:14px"><input type="checkbox" name="headshot"> Headshot</label>
          <label style="flex-direction:row;gap:4px;font-size:14px"><input type="checkbox" name="resume"> Resume</label>
        </div>
        <label>Song Length <input type="text" name="songLength" placeholder="e.g. 16 bars or 2 minutes"></label>
        <label>Callback Notes <input type="text" name="callbacks"></label>
        <label>Conflict Dates <input type="text" name="conflictDates"></label>
        <label>Additional Notes <textarea name="additionalNotes" rows="2"></textarea></label>

        <h3>Contact</h3>
        <label>Contact Name <input type="text" name="contactName"></label>
        <label>Contact Email <input type="email" name="contactEmail"></label>
        <label>Contact Phone <input type="tel" name="contactPhone"></label>

        <h3>Status</h3>
        <label>Status
          <select name="status">
            <option value="pending">Pending</option>
            <option value="published">Published</option>
          </select>
        </label>

        <button type="submit" class="btn" style="margin-top:8px">Add Audition</button>
      </form>
    </details>

    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Company</th>
          <th>First Audition</th>
          <th>Show Opens</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% auditions.forEach(a => { %>
          <tr>
            <td><strong><%= a.show && a.show.title %></strong></td>
            <td><%= a.linkedCompanyId && a.linkedCompanyId.name || '—' %></td>
            <td><%= a.auditionDates && a.auditionDates[0] && a.auditionDates[0].date ? new Date(a.auditionDates[0].date).toLocaleDateString() : '—' %></td>
            <td><%= a.show && a.show.showDates && a.show.showDates.opens ? new Date(a.show.showDates.opens).toLocaleDateString() : '—' %></td>
            <td><span class="status-badge status-<%= a.status %>"><%= a.status %></span></td>
            <td>
              <form method="POST" action="/admin/auditions/<%= a._id %>/status" style="display:inline">
                <% if (a.status !== 'published') { %>
                  <input type="hidden" name="status" value="published">
                  <button type="submit" class="btn btn-approve btn-sm">Publish</button>
                <% } else { %>
                  <input type="hidden" name="status" value="pending">
                  <button type="submit" class="btn btn-sm">Unpublish</button>
                <% } %>
              </form>
              <form method="POST" action="/admin/auditions/<%= a._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this audition?')">
                <button type="submit" class="btn btn-reject btn-sm">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (auditions.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;color:#999;padding:2rem">No auditions yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </main>
</body>
</html>
