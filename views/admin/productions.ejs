<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>NSC Admin — Productions</title>
  <link rel="stylesheet" href="/public/admin.css">
</head>
<body>
  <%- include('_nav') %>
  <main>
    <h1>Productions</h1>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <details class="form-panel">
      <summary>Add Production</summary>
      <form method="POST" action="/admin/productions">

        <h3 style="margin-top:0">Show Info</h3>
        <label>Title <input type="text" name="title" required></label>
        <label>Author <input type="text" name="author"></label>
        <label>Composer <input type="text" name="composer"></label>
        <label>Show Type
          <select name="showType">
            <option value="">—</option>
            <option value="musical">Musical</option>
            <option value="play">Play</option>
            <option value="improv">Improv</option>
            <option value="opera">Opera</option>
            <option value="dance">Dance</option>
            <option value="other">Other</option>
          </select>
        </label>
        <label>Family Rating
          <select name="familyRating">
            <option value="">—</option>
            <option value="G">G</option>
            <option value="PG">PG</option>
            <option value="PG-13">PG-13</option>
          </select>
        </label>
        <label>Runtime (e.g. "2 hrs 15 min") <input type="text" name="runtime"></label>
        <label>Content Warnings <input type="text" name="contentWarnings"></label>
        <label>Poster Image URL <input type="url" name="posterImageUrl"></label>
        <label>Description <textarea name="description" rows="3"></textarea></label>

        <h3>Company &amp; Venue</h3>
        <label>Company
          <select name="linkedCompanyId">
            <option value="">— Not linked —</option>
            <% companies.forEach(c => { %>
              <option value="<%= c._id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </label>
        <label>Venue
          <select name="linkedVenueId">
            <option value="">— Not linked —</option>
            <% venues.forEach(v => { %>
              <option value="<%= v._id %>"><%= v.name %></option>
            <% }) %>
          </select>
        </label>

        <h3>Run Dates</h3>
        <label>Opening Night <input type="date" name="opens"></label>
        <label>Closing Night <input type="date" name="closes"></label>

        <h3>Tickets</h3>
        <label>General Admission ($) <input type="number" name="ticketGeneral" step="0.01" min="0"></label>
        <label>Senior ($) <input type="number" name="ticketSenior" step="0.01" min="0"></label>
        <label>Student ($) <input type="number" name="ticketStudent" step="0.01" min="0"></label>
        <label>Child ($) <input type="number" name="ticketChild" step="0.01" min="0"></label>
        <label>Booking URL <input type="url" name="ticketUrl"></label>
        <label>Box Office Phone <input type="tel" name="boxOfficePhone"></label>
        <label>Ticket Notes <input type="text" name="ticketNotes"></label>

        <h3>Contact</h3>
        <label>Contact Name <input type="text" name="contactName"></label>
        <label>Contact Email <input type="email" name="contactEmail"></label>
        <label>Contact Phone <input type="tel" name="contactPhone"></label>

        <h3>Status</h3>
        <label>Status
          <select name="status">
            <option value="pending">Pending</option>
            <option value="published">Published</option>
          </select>
        </label>

        <button type="submit" class="btn" style="margin-top:8px">Add Production</button>
      </form>
    </details>

    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Company</th>
          <th>Venue</th>
          <th>Opens</th>
          <th>Closes</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% productions.forEach(p => { %>
          <tr>
            <td><strong><%= p.show && p.show.title %></strong></td>
            <td><%= p.linkedCompanyId && p.linkedCompanyId.name || '—' %></td>
            <td><%= p.linkedVenueId && p.linkedVenueId.name || '—' %></td>
            <td><%= p.dates && p.dates.opens ? new Date(p.dates.opens).toLocaleDateString() : '—' %></td>
            <td><%= p.dates && p.dates.closes ? new Date(p.dates.closes).toLocaleDateString() : '—' %></td>
            <td><span class="status-badge status-<%= p.status %>"><%= p.status %></span></td>
            <td>
              <form method="POST" action="/admin/productions/<%= p._id %>/status" style="display:inline">
                <% if (p.status !== 'published') { %>
                  <input type="hidden" name="status" value="published">
                  <button type="submit" class="btn btn-approve btn-sm">Publish</button>
                <% } else { %>
                  <input type="hidden" name="status" value="pending">
                  <button type="submit" class="btn btn-sm">Unpublish</button>
                <% } %>
              </form>
              <form method="POST" action="/admin/productions/<%= p._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this production?')">
                <button type="submit" class="btn btn-reject btn-sm">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (productions.length === 0) { %>
          <tr><td colspan="7" style="text-align:center;color:#999;padding:2rem">No productions yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </main>
</body>
</html>
