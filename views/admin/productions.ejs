<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>NSC Admin — Productions</title>
  <link rel="stylesheet" href="/public/admin.css">
  <style>
    .edit-form { padding: 16px 0; }
    .edit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .edit-grid label { display: flex; flex-direction: column; font-size: 12px; font-weight: 600; gap: 4px; }
    .edit-grid label input, .edit-grid label select, .edit-grid label textarea { font-size: 14px; padding: 6px 8px; border: 1px solid #ccc; border-radius: 4px; }
    .edit-grid .full { grid-column: span 2; }
    .edit-grid h4 { grid-column: span 2; margin: 10px 0 2px; font-size: 13px; text-transform: uppercase; letter-spacing: .5px; color: #555; border-bottom: 1px solid #eee; padding-bottom: 4px; }
    .btn-danger { background: #c00; color: #fff; border: none; }
    .btn-danger:hover { background: #900; }
    .poster-thumb { max-height: 80px; border-radius: 4px; display: block; margin-top: 6px; }
    .poster-upload-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
    .poster-upload-row input[type=file] { font-size: 13px; }
    .poster-upload-status { font-size: 12px; color: #666; }
    th.sortable { cursor: pointer; user-select: none; white-space: nowrap; }
    th.sortable:hover { background: #e8eef4; }
    .sort-icon { display: inline-block; margin-left: 4px; opacity: .4; font-style: normal; font-size: 11px; }
    th.sort-asc .sort-icon, th.sort-desc .sort-icon { opacity: 1; }
    th.sort-asc .sort-icon::after  { content: ' ▲'; }
    th.sort-desc .sort-icon::after { content: ' ▼'; }
    th.sortable:not(.sort-asc):not(.sort-desc) .sort-icon::after { content: ' ⇅'; }
    .checkbox-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 4px; }
    .checkbox-row label { flex-direction: row; gap: 4px; font-size: 14px; font-weight: normal; text-transform: capitalize; }
  </style>
</head>
<body>
  <%- include('_nav') %>
  <main>
    <h1>Productions</h1>

    <% if (error) { %><p class="error"><%= error %></p><% } %>

    <details class="form-panel">
      <summary>Add Production</summary>
      <form method="POST" action="/admin/productions">
        <h3 style="margin-top:0">Show Info</h3>
        <label>Title <input type="text" name="title" required></label>
        <label>Author <input type="text" name="author"></label>
        <label>Composer <input type="text" name="composer"></label>
        <div class="full">
          <label style="font-size:12px;font-weight:600;margin-bottom:4px;display:block">Show Type</label>
          <div class="checkbox-row">
            <% ['musical','play','drama','comedy','one_act','revue','opera','operetta','fringe','immersive','improv','reading','childrens','other'].forEach(function(t) { %>
              <label><input type="checkbox" name="showType" value="<%= t %>"> <%= t.replace('_',' ') %></label>
            <% }) %>
          </div>
        </div>
        <label>Family Rating
          <select name="familyRating">
            <option value="">—</option>
            <option value="G">G</option>
            <option value="PG">PG</option>
            <option value="PG-13">PG-13</option>
          </select>
        </label>
        <label>Runtime <input type="text" name="runtime" placeholder="e.g. 2 hrs 15 min"></label>
        <label>Content Warnings <input type="text" name="contentWarnings"></label>
        <label>Poster Image
          <div class="poster-upload-row">
            <input type="file" id="add-poster-file" accept="image/*" onchange="uploadPoster(this, 'add-poster-url', 'add-poster-preview', 'add-poster-status')">
            <span class="poster-upload-status" id="add-poster-status"></span>
          </div>
          <img id="add-poster-preview" class="poster-thumb" style="display:none" alt="Poster preview">
          <input type="hidden" name="posterImageUrl" id="add-poster-url">
        </label>
        <label>Description <textarea name="description" rows="3"></textarea></label>

        <h3>Company &amp; Venue</h3>
        <label>Company
          <select name="linkedCompanyId" id="add-company-sel" onchange="filterVenues(this, 'add-venue-sel')">
            <option value="">— Not linked —</option>
            <% companies.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
          </select>
        </label>
        <label>Venue
          <select name="linkedVenueId" id="add-venue-sel">
            <option value="">— Not linked —</option>
            <% venues.forEach(v => { %><option value="<%= v._id %>" data-venue-id="<%= v._id %>"><%= v.name %></option><% }) %>
          </select>
        </label>

        <h3>Run Dates &amp; Showtimes</h3>
        <label>Opening Night <input type="date" name="opens"></label>
        <label>Closing Night <input type="date" name="closes"></label>
        <label class="full">Showtimes <textarea name="showtimes" rows="3" placeholder="e.g. Fri & Sat 7:30pm&#10;Sun 2:00pm&#10;Matinees available"></textarea></label>

        <h3>Tickets</h3>
        <label>General Admission <input type="text" name="ticketGeneral" placeholder="e.g. $20 or $15–$25"></label>
        <label>Adult <input type="text" name="ticketAdult" placeholder="e.g. $22"></label>
        <label>Senior <input type="text" name="ticketSenior" placeholder="e.g. $18"></label>
        <label>Student <input type="text" name="ticketStudent" placeholder="e.g. $12"></label>
        <label>Child <input type="text" name="ticketChild" placeholder="e.g. Free under 5"></label>
        <label>Booking URL <input type="url" name="ticketUrl"></label>
        <label>Box Office Phone <input type="tel" name="boxOfficePhone"></label>
        <label>Ticket Notes <input type="text" name="ticketNotes"></label>

        <h3>Contact</h3>
        <label>Contact Name <input type="text" name="contactName"></label>
        <label>Contact Email <input type="email" name="contactEmail"></label>
        <label>Contact Phone <input type="tel" name="contactPhone"></label>

        <h3>Status</h3>
        <label>Status
          <select name="status">
            <option value="pending">Pending</option>
            <option value="published">Published</option>
          </select>
        </label>

        <button type="submit" class="btn" style="margin-top:8px">Add Production</button>
      </form>
    </details>

    <table>
      <thead>
        <tr>
          <th class="sortable" data-col="0">Title<i class="sort-icon"></i></th>
          <th class="sortable" data-col="1">Company<i class="sort-icon"></i></th>
          <th class="sortable" data-col="2">Venue<i class="sort-icon"></i></th>
          <th class="sortable" data-col="3">Opens<i class="sort-icon"></i></th>
          <th class="sortable" data-col="4">Closes<i class="sort-icon"></i></th>
          <th class="sortable" data-col="5">Status<i class="sort-icon"></i></th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% productions.forEach(p => { %>
          <tr>
            <td><strong><%= p.show && p.show.title %></strong></td>
            <td><%= p.linkedCompanyId && p.linkedCompanyId.name || '—' %></td>
            <td><%= p.linkedVenueId && p.linkedVenueId.name || '—' %></td>
            <td><%= p.dates && p.dates.opens ? new Date(p.dates.opens).toLocaleDateString() : '—' %></td>
            <td><%= p.dates && p.dates.closes ? new Date(p.dates.closes).toLocaleDateString() : '—' %></td>
            <td><span class="status-badge status-<%= p.status %>"><%= p.status %></span></td>
            <td>
              <button class="btn-sm" onclick="toggleEdit('<%= p._id %>')">Edit</button>
              <form method="POST" action="/admin/productions/<%= p._id %>/status" style="display:inline">
                <% if (p.status !== 'published') { %>
                  <input type="hidden" name="status" value="published">
                  <button type="submit" class="btn btn-approve btn-sm">Publish</button>
                <% } else { %>
                  <input type="hidden" name="status" value="pending">
                  <button type="submit" class="btn btn-sm">Unpublish</button>
                <% } %>
              </form>
              <form method="POST" action="/admin/productions/<%= p._id %>/clone" style="display:inline" onsubmit="return confirm('Clone this production?')">
                <button type="submit" class="btn btn-sm">Clone</button>
              </form>
              <form method="POST" action="/admin/productions/<%= p._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this production?')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
            </td>
          </tr>
          <tr id="edit-<%= p._id %>" style="display:none">
            <td colspan="7">
              <form method="POST" action="/admin/productions/<%= p._id %>" class="edit-form">
                <div class="edit-grid">
                  <h4>Show Info</h4>
                  <label class="full">Title <input type="text" name="title" value="<%= p.show && p.show.title %>" required></label>
                  <label>Author <input type="text" name="author" value="<%= p.show && p.show.author %>"></label>
                  <label>Composer <input type="text" name="composer" value="<%= p.show && p.show.composer %>"></label>
                  <div class="full">
                    <label style="font-size:12px;font-weight:600;margin-bottom:4px;display:block">Show Type</label>
                    <div class="checkbox-row">
                      <% ['musical','play','drama','comedy','one_act','revue','opera','operetta','fringe','immersive','improv','reading','childrens','other'].forEach(function(t) { %>
                        <label><input type="checkbox" name="showType" value="<%= t %>" <%- p.show && p.show.showType && p.show.showType.indexOf(t) > -1 ? 'checked' : '' %>> <%= t.replace('_',' ') %></label>
                      <% }) %>
                    </div>
                  </div>
                  <label>Family Rating
                    <select name="familyRating">
                      <option value="">—</option>
                      <% ['G','PG','PG-13'].forEach(r => { %>
                        <option <%- (p.show && p.show.familyRating) === r ? 'selected' : '' %>><%= r %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label>Runtime <input type="text" name="runtime" value="<%= p.show && p.show.runtime %>"></label>
                  <label class="full">Content Warnings <input type="text" name="contentWarnings" value="<%= p.show && p.show.contentWarnings %>"></label>
                  <label class="full">Description <textarea name="description" rows="4"><%= p.show && p.show.description %></textarea></label>

                  <label class="full">
                    Poster Image
                    <div class="poster-upload-row">
                      <input type="file" accept="image/*" onchange="uploadPoster(this, 'poster-url-<%= p._id %>', 'poster-preview-<%= p._id %>', 'poster-status-<%= p._id %>')">
                      <span class="poster-upload-status" id="poster-status-<%= p._id %>"></span>
                    </div>
                    <% if (p.show && p.show.posterImageUrl) { %>
                      <img src="<%= p.show.posterImageUrl %>" class="poster-thumb" id="poster-preview-<%= p._id %>" alt="Poster">
                    <% } else { %>
                      <img class="poster-thumb" id="poster-preview-<%= p._id %>" style="display:none" alt="Poster preview">
                    <% } %>
                    <input type="hidden" name="posterImageUrl" id="poster-url-<%= p._id %>" value="<%= p.show && p.show.posterImageUrl || '' %>">
                  </label>

                  <h4>Company &amp; Venue</h4>
                  <label>Company
                    <select name="linkedCompanyId" id="edit-company-<%= p._id %>" onchange="filterVenues(this, 'edit-venue-<%= p._id %>')">
                      <option value="">— Not linked —</option>
                      <% companies.forEach(c => { %>
                        <option value="<%= c._id %>" <%- String(p.linkedCompanyId && p.linkedCompanyId._id) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label>Venue
                    <select name="linkedVenueId" id="edit-venue-<%= p._id %>">
                      <option value="">— Not linked —</option>
                      <% venues.forEach(v => { %>
                        <option value="<%= v._id %>" data-venue-id="<%= v._id %>" <%- String(p.linkedVenueId && p.linkedVenueId._id) === String(v._id) ? 'selected' : '' %>><%= v.name %></option>
                      <% }) %>
                    </select>
                  </label>

                  <h4>Run Dates &amp; Showtimes</h4>
                  <label>Opening Night <input type="date" name="opens" value="<%= p.dates && p.dates.opens ? new Date(p.dates.opens).toISOString().slice(0,10) : '' %>"></label>
                  <label>Closing Night <input type="date" name="closes" value="<%= p.dates && p.dates.closes ? new Date(p.dates.closes).toISOString().slice(0,10) : '' %>"></label>
                  <label class="full">Showtimes <textarea name="showtimes" rows="3"><%= p.showtimes %></textarea></label>

                  <h4>Tickets</h4>
                  <label>General Admission <input type="text" name="ticketGeneral" placeholder="e.g. $20 or $15–$25" value="<%= p.tickets && p.tickets.generalAdmission %>"></label>
                  <label>Adult <input type="text" name="ticketAdult" placeholder="e.g. $22" value="<%= p.tickets && p.tickets.adult %>"></label>
                  <label>Senior <input type="text" name="ticketSenior" placeholder="e.g. $18" value="<%= p.tickets && p.tickets.senior %>"></label>
                  <label>Student <input type="text" name="ticketStudent" placeholder="e.g. $12" value="<%= p.tickets && p.tickets.student %>"></label>
                  <label>Child <input type="text" name="ticketChild" placeholder="e.g. Free under 5" value="<%= p.tickets && p.tickets.child %>"></label>
                  <label class="full">Booking URL <input type="url" name="ticketUrl" value="<%= p.tickets && p.tickets.bookingUrl %>"></label>
                  <label>Box Office Phone <input type="tel" name="boxOfficePhone" value="<%= p.tickets && p.tickets.boxOfficePhone %>"></label>
                  <label class="full">Ticket Notes <input type="text" name="ticketNotes" value="<%= p.tickets && p.tickets.notes %>"></label>

                  <h4>Contact &amp; Admin</h4>
                  <label>Contact Name <input type="text" name="contactName" value="<%= p.contactName %>"></label>
                  <label>Contact Email <input type="email" name="contactEmail" value="<%= p.contactEmail %>"></label>
                  <label>Contact Phone <input type="tel" name="contactPhone" value="<%= p.contactPhone %>"></label>
                  <label class="full">Admin Notes <textarea name="adminNotes" rows="2"><%= p.adminNotes %></textarea></label>
                  <label>Status
                    <select name="status">
                      <% ['pending','published','closed','rejected'].forEach(s => { %>
                        <option value="<%= s %>" <%- p.status === s ? 'selected' : '' %>><%= s %></option>
                      <% }) %>
                    </select>
                  </label>
                </div>
                <div style="margin-top:14px;display:flex;gap:8px">
                  <button type="submit" class="btn">Save Changes</button>
                  <button type="button" class="btn-sm" onclick="toggleEdit('<%= p._id %>')">Cancel</button>
                </div>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (productions.length === 0) { %>
          <tr><td colspan="7" style="text-align:center;color:#999;padding:2rem">No productions yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </main>

  <script>
    // Company → homeVenueIds map (from server)
    var COMPANY_VENUES = <%- JSON.stringify(
      companies.reduce(function(acc, c) {
        acc[String(c._id)] = (c.homeVenueIds || []).map(String);
        return acc;
      }, {})
    ) %>;

    function filterVenues(companySel, venueSelId) {
      var companyId = companySel.value;
      var venueSel  = document.getElementById(venueSelId);
      var current   = venueSel.value;
      var venueIds  = companyId ? (COMPANY_VENUES[companyId] || []) : null;

      Array.from(venueSel.options).forEach(function (opt) {
        if (!opt.value) return; // keep the "— Not linked —" option
        var show = !venueIds || venueIds.indexOf(opt.dataset.venueId) !== -1;
        opt.hidden   = !show;
        opt.disabled = !show;
      });

      // If current selection is now hidden, reset to blank
      if (current && venueSel.options[venueSel.selectedIndex] && venueSel.options[venueSel.selectedIndex].hidden) {
        venueSel.value = '';
      }
    }

    function toggleEdit(id) {
      var row = document.getElementById('edit-' + id);
      row.style.display = row.style.display === 'none' ? '' : 'none';
    }

    (function () {
      var tbody = document.querySelector('table tbody');
      var lastCol = -1;
      var asc = true;

      function cellText(row, col) {
        // For edit rows (colspan), skip — they travel with their data row
        var cells = row.querySelectorAll('td');
        if (!cells[col]) return '';
        return cells[col].textContent.trim();
      }

      function sortTable(col) {
        if (col === lastCol) {
          asc = !asc;
        } else {
          asc = true;
          lastCol = col;
        }

        // Collect data rows and their paired edit rows
        var allRows = Array.from(tbody.querySelectorAll('tr'));
        var pairs = [];
        for (var i = 0; i < allRows.length; i++) {
          var r = allRows[i];
          if (r.id && r.id.startsWith('edit-')) continue; // skip, paired below
          var editRow = allRows[i + 1];
          pairs.push({ data: r, edit: (editRow && editRow.id && editRow.id.startsWith('edit-')) ? editRow : null });
        }

        pairs.sort(function (a, b) {
          var av = cellText(a.data, col);
          var bv = cellText(b.data, col);
          // Dates: cols 3 and 4
          if (col === 3 || col === 4) {
            var ad = av === '—' ? 0 : new Date(av).getTime();
            var bd = bv === '—' ? 0 : new Date(bv).getTime();
            return asc ? ad - bd : bd - ad;
          }
          return asc ? av.localeCompare(bv) : bv.localeCompare(av);
        });

        // Re-append pairs in sorted order
        pairs.forEach(function (p) {
          tbody.appendChild(p.data);
          if (p.edit) tbody.appendChild(p.edit);
        });

        // Update header indicators
        document.querySelectorAll('th.sortable').forEach(function (th) {
          th.classList.remove('sort-asc', 'sort-desc');
          if (parseInt(th.dataset.col) === col) {
            th.classList.add(asc ? 'sort-asc' : 'sort-desc');
          }
        });
      }

      document.querySelectorAll('th.sortable').forEach(function (th) {
        th.addEventListener('click', function () {
          sortTable(parseInt(this.dataset.col));
        });
      });
    })();


    function uploadPoster(fileInput, urlId, previewId, statusId) {
      var file = fileInput.files[0];
      if (!file) return;
      var statusEl  = document.getElementById(statusId);
      var previewEl = document.getElementById(previewId);
      var urlEl     = document.getElementById(urlId);
      statusEl.textContent = 'Uploading…';
      var fd = new FormData();
      fd.append('file', file);
      fetch('/webhook/upload-image', { method: 'POST', body: fd })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.url) throw new Error('No URL');
          urlEl.value = data.url;
          statusEl.textContent = 'Uploaded ✓';
          previewEl.src = data.url;
          previewEl.style.display = 'block';
        })
        .catch(function () {
          statusEl.textContent = 'Upload failed — try again.';
        });
    }
  </script>
</body>
</html>
